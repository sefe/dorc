		  <Json:JsonFile Id="PropertyValueCreationCopyEnvBuildConfigDorcApiClientSecret" ElementPath="$.DorcApi.ClientSecret" Value="[DORC.API.CLIENTSECRET]" File="[#PropertyValueCreationConfig]" />
