<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="MSBuild.Sdk.SqlProj/4.2.0">
  <PropertyGroup>
    <Name>Deploy.Database</Name>
    <TargetFramework>netstandard2.0</TargetFramework>
    <ProjectGuid>{81a46968-2261-4685-9a68-f0816fdab051}</ProjectGuid>
    <SqlServerVersion>Sql150</SqlServerVersion>
    <!-- Legacy install pipeline (CopyDeploymentArtefactsBeforePublish.ps1 +
         DeploySettings.template.json) hard-codes the dacpac name 'Dorc.Database.dacpac'
         and looks for sibling '.PreSQL.sql'/'.PostSQL.sql' artefacts. Keep AssemblyName
         aligned with that contract — the legacy '<AssemblyName>DevOps.Dorc.Database</AssemblyName>'
         only governed an additional .dll the modern SDK no longer emits. -->
    <AssemblyName>Dorc.Database</AssemblyName>
    <RootNamespace>Dorc.Database</RootNamespace>
    <DefaultSchema>dbo</DefaultSchema>
    <ModelCollation>1033,CI</ModelCollation>
    <DefaultCollation>SQL_Latin1_General_CP1_CI_AS</DefaultCollation>
    <CompatibilityMode>100</CompatibilityMode>
    <TreatTSqlWarningsAsErrors>False</TreatTSqlWarningsAsErrors>
    <ValidateCasingOnIdentifiers>False</ValidateCasingOnIdentifiers>
    <!-- Pipeline (pipelines/dorc-build.yml) reads dacpac from src\Dorc.Database\sql\$(Configuration). -->
    <BaseOutputPath>sql\</BaseOutputPath>
    <OutputPath>sql\$(Configuration)\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|AnyCPU'">
    <TargetDatabase>Deploy.Database</TargetDatabase>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x64'">
    <TargetDatabase>DeploymentV2</TargetDatabase>
  </PropertyGroup>
  <ItemGroup>
    <!-- Default SDK glob compiles **/*.sql via <Content>. The Scripts folder
         holds operational pre/post-deployment + ad-hoc maintenance scripts;
         none belong in the compiled model. Exclude the whole folder; the
         pre/post-deployment scripts are wired in via PreDeployment / PostDeployment
         build actions below. -->
    <Content Remove="Scripts\**\*.sql" />
    <None Include="Scripts\**\*.sql" />
    <PreDeploy Include="Scripts\Pre-Deployment\Script.PreDeployment.sql" />
    <PostDeploy Include="Scripts\Post-Deployment\Script.PostDeployment.sql" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Schema Comparisons\LocalToProject.scmp" />
    <!-- Empty placeholders consumed by the install pipeline alongside the
         dacpac (see CopyDeploymentArtefactsBeforePublish.ps1 AdditionalExtnSearch).
         Copied to sql\$(Configuration)\ so the build output matches the
         legacy SSDT layout. -->
    <None Include="Dorc.Database.PreSQL.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="Dorc.Database.PostSQL.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <ItemGroup>
    <SqlCmdVariable Include="EnvironmentName">
      <DefaultValue>
      </DefaultValue>
      <Value>$(SqlCmdVar__1)</Value>
    </SqlCmdVariable>
  </ItemGroup>
  <ItemGroup>
    <RefactorLog Include="Dorc.Database.refactorlog" />
  </ItemGroup>
</Project>
